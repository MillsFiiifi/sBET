# Get a free key at https://the-odds-api.com (500 requests/month)
ODDS_API_KEY=your_key_here

# Password gate for /admin/*. Leave unset to disable the admin section entirely.
ADMIN_PASSWORD=change-me

# Moolre (https://app.moolre.com) — hosted-checkout payment gateway for Ghana
# mobile money (MTN, Telecel Cash, AT Money). All values are server-side
# secrets; do NOT prefix any of them with NEXT_PUBLIC_.
#
# MOOLRE_PUBLIC_KEY   — the "Public Key" (JWT) shown on your Moolre profile
#                       page. Sent as `X-Api-Pubkey` on every API call.
# MOOLRE_ACCOUNT_NUMBER — your merchant account number from the dashboard.
# MOOLRE_PRIVATE_KEY  — reserved for the payouts/disbursement API (not used
#                       yet by this app, but keep it in env for completeness).
# MOOLRE_SECRET_KEY   — reserved for webhook signature verification (not used
#                       yet — server-to-server `state=confirm` re-verification
#                       is the source of truth).
MOOLRE_PUBLIC_KEY=
MOOLRE_ACCOUNT_NUMBER=
MOOLRE_PRIVATE_KEY=
MOOLRE_SECRET_KEY=

# Minimum first deposit in GHS
MIN_FIRST_DEPOSIT=200

# Supabase (https://supabase.com) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Never commit; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Customer Service / Contact Support button → opens t.me/<handle>.
# Leave unset to default to "PrimeBet_Africa". Just the username, no @ or URL.
NEXT_PUBLIC_TELEGRAM_SUPPORT_HANDLE=PrimeBet_Africa
